{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SipSession",
  "type": "object",
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "callId": {
      "type": "string",
      "description": "SIP Call-ID"
    },
    "callGuid": {
      "type": "string",
      "description": "Associated CVP call GUID"
    },
    "state": {
      "type": "string"
    },
    "method": {
      "type": "string",
      "description": "Initial SIP method (INVITE)"
    },
    "fromUri": {
      "type": "string"
    },
    "toUri": {
      "type": "string"
    },
    "startTime": {
      "type": "string"
    }
  }
}