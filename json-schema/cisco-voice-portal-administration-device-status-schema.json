{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeviceStatus",
  "type": "object",
  "properties": {
    "deviceId": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "services": {
      "type": "array"
    },
    "cpuUsage": {
      "type": "number",
      "description": "CPU usage percentage"
    },
    "memoryUsage": {
      "type": "number",
      "description": "Memory usage percentage"
    },
    "activeCalls": {
      "type": "integer",
      "description": "Number of active calls on this device"
    },
    "timestamp": {
      "type": "string"
    }
  }
}