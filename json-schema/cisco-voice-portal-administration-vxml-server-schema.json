{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VxmlServer",
  "type": "object",
  "properties": {
    "serverId": {
      "type": "string"
    },
    "hostname": {
      "type": "string"
    },
    "ipAddress": {
      "type": "string"
    },
    "httpPort": {
      "type": "integer"
    },
    "httpsPort": {
      "type": "integer"
    },
    "status": {
      "type": "string"
    },
    "deployedApplications": {
      "type": "integer",
      "description": "Number of applications deployed on this server"
    }
  }
}