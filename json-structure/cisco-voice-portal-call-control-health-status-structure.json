{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "HealthStatus",
  "type": "object",
  "properties": {
    "serverName": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "uptime": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "activeCalls": {
      "type": "integer"
    },
    "maxCalls": {
      "type": "integer"
    },
    "sipStackStatus": {
      "type": "string"
    },
    "cpuUsage": {
      "type": "number"
    },
    "memoryUsage": {
      "type": "number"
    },
    "timestamp": {
      "type": "string"
    }
  }
}